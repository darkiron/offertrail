# Base de données
DATABASE_URL=sqlite:///./offertrail.db

# Supabase Auth — OBLIGATOIRE en prod
# JWT Secret : Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=      # Settings → API → service_role key

# Stripe (optionnel en local)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ⚠️ PRICE ID — commence par price_ (pas prod_) : Dashboard → Products → ton produit → copier l'ID du prix
STRIPE_PRICE_ID=price_...
# Pour activer Stripe en local : mettre ENABLE_STRIPE_CHECKOUT=1
# Tester les webhooks : stripe listen --forward-to localhost:8000/subscription/webhook
ENABLE_STRIPE_CHECKOUT=

# Email Resend (optionnel en local)
RESEND_API_KEY=

# CORS - séparer par virgule
ALLOWED_ORIGINS=http://localhost:5173

# URL de l'app (pour les redirects Stripe)
APP_BASE_URL=http://localhost:5173
